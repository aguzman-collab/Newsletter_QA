{
  "devDependencies": {
    "cypress": "^15.12.0",
    "cypress-iframe": "^1.0.1",
    "cypress-xpath": "^2.0.1",
    "dotenv": "^17.3.1",
    "lighthouse": "^13.0.3",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "puppeteer": "^24.40.0",
    "rimraf": "^6.1.3"
  },
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "clean:reports": "rimraf cypress/reports",
    "merge-reports": "mochawesome-merge cypress/reports/.jsons/*.json > cypress/reports/mochawesome.json",
    "generate-html": "marge cypress/reports/mochawesome.json --reportDir cypress/reports --reportFilename index",
    "generate-pdf": "node cypress/scripts/generate-pdf.js",
    "report:pdf": "rimraf cypress/reports && cypress run --spec cypress/e2e/nutraapp.cy.js && npm run merge-reports && npm run generate-html && npm run generate-pdf && npm run lighthouse",
    "lighthouse": "lighthouse https://newsletter.nutrabiotics.com.co/ --output html --output-path ./cypress/reports/lighthouse.html"
  },
  "dependencies": {
    "cypress-mochawesome-reporter": "^4.0.2"
  }
}
